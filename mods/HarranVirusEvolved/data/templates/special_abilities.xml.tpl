<?xml version="1.0" encoding="utf-8"?>
<SpecialAbilities modName="${MOD_NAME}" modVersion="${MOD_VERSION}">
  <Echolocation
    enabled="${DEATH_ANGEL_ABILITIES_ECHOLOCATION_ENABLED}"
    triggerDistanceMeters="${DEATH_ANGEL_ABILITIES_ECHOLOCATION_NOISE_TRIGGER_DISTANCE_METERS}"
    investigateSeconds="${DEATH_ANGEL_ABILITIES_ECHOLOCATION_INVESTIGATION_DURATION_SECONDS}" />

  <ArmorPlating
    enabled="${DEATH_ANGEL_ABILITIES_ARMOR_PLATING_ENABLED}"
    frontalDamageReduction="${DEATH_ANGEL_ABILITIES_ARMOR_PLATING_FRONTAL_DAMAGE_REDUCTION}"
    openPlateCriticalBonus="${DEATH_ANGEL_ABILITIES_ARMOR_PLATING_OPENED_PLATE_CRITICAL_BONUS}"
    openPlateWindowSeconds="${DEATH_ANGEL_ABILITIES_ARMOR_PLATING_OPENED_PLATE_WINDOW_SECONDS}" />

  <HyperDash
    enabled="${DEATH_ANGEL_ABILITIES_HYPER_DASH_ENABLED}"
    cooldownSeconds="${DEATH_ANGEL_ABILITIES_HYPER_DASH_COOLDOWN_SECONDS}"
    speedMultiplier="${DEATH_ANGEL_ABILITIES_HYPER_DASH_DASH_SPEED_MULTIPLIER}"
    distanceMeters="${DEATH_ANGEL_ABILITIES_HYPER_DASH_DASH_DISTANCE_METERS}" />
</SpecialAbilities>
